

@import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600&family=Bebas+Neue&display=swap');

:root {
  --blue        : #1565C0;
  --blue-light  : #1E88E5;
  --blue-bright : #42A5F5;
  --blue-glow   : rgba(30,136,229,.35);
  --red         : #D32F2F;
  --red-light   : #EF5350;
  --red-glow    : rgba(211,47,47,.28);
  --green       : #00C853;
  --green-dark  : #00A040;
  --green-glow  : rgba(0,200,83,.35);
  --white       : #ffffff;
  --dark        : #080C1A;
  --dark2       : #0D1428;
  --card-bg     : #0F1729;
  --card-border : rgba(66,165,245,.18);
  --text        : #E8EEFF;
  --text-soft   : #8BA3C7;
  --text-dim    : #4A6080;
  --radius-sm   : 10px;
  --radius-md   : 16px;
  --radius-lg   : 40px;
  --shadow-card : 0 4px 24px rgba(0,0,0,.45), 0 0 0 1px var(--card-border);
  --tr          : .22s cubic-bezier(.4,0,.2,1);
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--dark);color:var(--text);font-family:'Inter',sans-serif;min-height:100vh;line-height:1.6;overflow-x:hidden;}

/* ─────────────────────────────────────────────
   OFFICIAL NOTICE BANNER
───────────────────────────────────────────── */
.official-notice {
  position: relative;
  z-index: 3;
  background: linear-gradient(90deg, #0D1F4A 0%, #112255 40%, #1A1000 70%, #2A0A00 100%);
  border-bottom: 2px solid rgba(66,165,245,.35);
  padding: 10px 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  overflow: hidden;
}

.official-notice::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    90deg,
    transparent 0px,
    transparent 60px,
    rgba(66,165,245,.04) 60px,
    rgba(66,165,245,.04) 61px
  );
  pointer-events: none;
}

.notice-shield {
  font-size: 1.05rem;
  animation: shieldPulse 2s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes shieldPulse {
  0%,100%{transform:scale(1);filter:drop-shadow(0 0 4px rgba(66,165,245,.6));}
  50%{transform:scale(1.15);filter:drop-shadow(0 0 10px rgba(66,165,245,.9));}
}

.notice-text {
  font-size: .78rem;
  font-weight: 800;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #fff;
  text-shadow: 0 0 12px rgba(66,165,245,.8);
  text-align: center;
  animation: noticePulse 3s ease-in-out infinite;
}

@keyframes noticePulse {
  0%,100%{opacity:.85;}
  50%{opacity:1;text-shadow:0 0 18px rgba(66,165,245,1),0 0 30px rgba(211,47,47,.4);}
}

/* ─────────────────────────────────────────────
   HEADER
───────────────────────────────────────────── */
.site-header{
  position:relative;
  background:linear-gradient(160deg,#040818 0%,#0A1535 55%,#0D1F4A 100%);
  border-bottom:1px solid rgba(66,165,245,.2);
  overflow:hidden;
}

.header-particles{position:absolute;inset:0;pointer-events:none;z-index:0;}

.header-glow{
  position:absolute;width:700px;height:500px;
  background:radial-gradient(circle,rgba(30,136,229,.16) 0%,transparent 70%);
  top:-180px;left:50%;transform:translateX(-50%);
  pointer-events:none;z-index:0;
  animation:glowPulse 4.5s ease-in-out infinite;
}
@keyframes glowPulse{
  0%,100%{opacity:.5;transform:translateX(-50%) scale(1);}
  50%{opacity:1;transform:translateX(-50%) scale(1.1);}
}

.header-inner{
  position:relative;z-index:2;
  max-width:1280px;margin:0 auto;
  padding:20px 24px 16px;
  display:flex;align-items:center;gap:16px;flex-wrap:wrap;
}

.header-logo{display:flex;flex-direction:column;gap:5px;flex:1;min-width:160px;}

.logo-badge{display:flex;align-items:center;gap:10px;}

.logo-icon{
  font-size:1.6rem;
  filter:drop-shadow(0 0 10px #42A5F5);
  animation:iconFloat 3s ease-in-out infinite;
}
@keyframes iconFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-5px);}}

.logo-text{
  font-family:'Bebas Neue',sans-serif;font-size:1.85rem;
  letter-spacing:.08em;color:#fff;line-height:1;
  text-shadow:0 0 22px rgba(66,165,245,.55);
}
.logo-text span{color:var(--blue-bright);}

.live-indicator{display:flex;align-items:center;gap:7px;font-size:.76rem;font-weight:600;color:var(--text-soft);}

.live-dot{
  width:9px;height:9px;background:#00E676;border-radius:50%;
  box-shadow:0 0 8px #00E676;flex-shrink:0;
  animation:livePulse 1.5s infinite;
}
@keyframes livePulse{
  0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 8px #00E676;}
  50%{opacity:.55;transform:scale(1.45);box-shadow:0 0 16px #00E676;}
}

.header-right{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}

/* Lang */
.lang-switcher{
  display:flex;gap:5px;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.1);
  border-radius:30px;padding:4px;
}
.lang-btn{
  background:transparent;border:none;color:var(--text-soft);
  font-size:.8rem;font-weight:700;font-family:inherit;
  padding:6px 13px;border-radius:24px;cursor:pointer;transition:var(--tr);white-space:nowrap;
}
.lang-btn.active,.lang-btn:hover{background:var(--blue);color:#fff;box-shadow:0 0 12px var(--blue-glow);}

/* Contact buttons */
.header-contacts{display:flex;gap:9px;flex-wrap:wrap;}
.contact-btn{
  display:inline-flex;align-items:center;gap:7px;
  padding:10px 16px;border-radius:var(--radius-lg);
  font-weight:700;font-size:.86rem;text-decoration:none;
  transition:var(--tr);white-space:nowrap;
}
.telegram-color{
  background:linear-gradient(135deg,#0088CC,#0099E6);color:#fff;
  box-shadow:0 4px 14px rgba(0,136,204,.4);
}
.telegram-color:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,136,204,.6);}

/* ZANGI — GREEN */
.zangi-color{
  background:linear-gradient(135deg,var(--green-dark),var(--green));color:#fff;
  box-shadow:0 4px 14px var(--green-glow);
}
.zangi-color:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,200,83,.55);}

/* Marquee */
.header-marquee-wrap{
  position:relative;z-index:2;
  background:linear-gradient(135deg,var(--red) 0%,#B71C1C 50%,var(--red) 100%);
  overflow:hidden;height:36px;display:flex;align-items:center;
  border-top:1px solid rgba(255,255,255,.1);
}
.header-marquee{
  display:flex;white-space:nowrap;
  animation:marquee 30s linear infinite;
  font-size:.76rem;font-weight:800;letter-spacing:.08em;
  color:rgba(255,255,255,.95);text-transform:uppercase;
}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ─────────────────────────────────────────────
   CONTAINER
───────────────────────────────────────────── */
.container{max-width:1280px;margin:0 auto;padding:44px 20px 80px;}

.section-eyebrow{display:flex;align-items:center;gap:14px;margin-bottom:8px;}
.eyebrow-line{flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(66,165,245,.4),transparent);}
.eyebrow-content{display:flex;align-items:center;gap:8px;}
.eyebrow-icon{font-size:.95rem;}
.eyebrow-label{font-size:.7rem;font-weight:800;letter-spacing:.16em;color:var(--blue-bright);text-transform:uppercase;}

.section-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2rem,5vw,3rem);
  color:#fff;letter-spacing:.04em;margin-bottom:32px;
  position:relative;display:inline-block;
}
.title-underline{
  display:block;height:3px;
  background:linear-gradient(90deg,var(--blue-light),var(--red-light),transparent);
  border-radius:2px;margin-top:4px;
  animation:underlineGrow .8s cubic-bezier(.4,0,.2,1) .3s both;
  transform-origin:left;
}
@keyframes underlineGrow{from{transform:scaleX(0);}to{transform:scaleX(1);}}

/* ─────────────────────────────────────────────
   GRID
───────────────────────────────────────────── */
.products-grid{display:grid;grid-template-columns:1fr;gap:30px;}
@media(min-width:700px){.products-grid{grid-template-columns:repeat(2,1fr);}}
@media(min-width:1100px){.products-grid{grid-template-columns:repeat(3,1fr);}}

/* ─────────────────────────────────────────────
   PRODUCT CARD
───────────────────────────────────────────── */
.product-card{
  background:var(--card-bg);border-radius:var(--radius-md);
  border:1px solid var(--card-border);overflow:hidden;
  display:flex;flex-direction:column;
  box-shadow:var(--shadow-card);
  transition:transform .28s cubic-bezier(.4,0,.2,1),box-shadow .28s cubic-bezier(.4,0,.2,1);
  position:relative;
  animation:cardIn .5s cubic-bezier(.4,0,.2,1) both;
}
@keyframes cardIn{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
.product-card:hover{transform:translateY(-7px);box-shadow:var(--shadow-card),0 14px 42px var(--blue-glow);}

/* VIDEO */
.video-wrapper{position:relative;width:100%;aspect-ratio:16/9;background:#000;overflow:hidden;}
.product-video{width:100%;height:100%;object-fit:cover;display:block;}
.video-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(5,10,30,.9) 0%,transparent 55%);
  pointer-events:none;z-index:1;
}

/* TOP-LEFT: Proof button — solid blue, fully visible */
.proof-btn{
  position:absolute;top:10px;left:10px;z-index:4;
  background:rgba(21,101,192,.92);
  border:1.5px solid rgba(66,165,245,.7);
  color:#fff;font-size:.73rem;font-weight:800;
  padding:5px 12px;border-radius:20px;cursor:pointer;
  display:flex;align-items:center;gap:5px;
  transition:var(--tr);white-space:nowrap;
  box-shadow:0 2px 10px rgba(0,0,0,.5),0 0 8px rgba(66,165,245,.4);
}
.proof-btn:hover{background:rgba(21,101,192,1);transform:scale(1.06);box-shadow:0 4px 16px rgba(66,165,245,.6);}

/* TOP-RIGHT: Badges — solid blue bg */
.vid-badges{
  position:absolute;top:10px;right:10px;z-index:4;
  display:flex;flex-direction:column;gap:5px;align-items:flex-end;
}
.vid-badge{
  padding:4px 11px;border-radius:20px;
  font-size:.7rem;font-weight:800;letter-spacing:.04em;
  white-space:nowrap;
  border:1.5px solid transparent;
  box-shadow:0 2px 10px rgba(0,0,0,.5);
  animation:badgeIn .4s cubic-bezier(.4,0,.2,1) both;
}
@keyframes badgeIn{from{transform:scale(.8) translateX(8px);opacity:0;}to{transform:scale(1) translateX(0);opacity:1;}}
.vid-badge.hot   {background:rgba(211,47,47,.92);color:#fff;border-color:rgba(239,83,80,.7);}
.vid-badge.vip   {background:rgba(0,150,136,.92);color:#fff;border-color:rgba(0,200,183,.6);}
.vid-badge.new   {background:rgba(21,101,192,.92);color:#fff;border-color:rgba(66,165,245,.7);}
.vid-badge.seller{background:rgba(255,143,0,.92);color:#000;border-color:rgba(255,179,0,.7);}

/* BOTTOM HUD */
.vid-center-hud{
  position:absolute;bottom:0;left:0;right:0;z-index:3;
  padding:7px 12px 10px;
  display:flex;align-items:center;justify-content:space-between;gap:8px;
}
.vid-views{
  display:flex;align-items:center;gap:6px;font-size:.72rem;font-weight:700;color:#fff;
  background:rgba(21,101,192,.85);
  padding:4px 10px;border-radius:20px;
  border:1px solid rgba(66,165,245,.5);
  box-shadow:0 2px 8px rgba(0,0,0,.4);
}
.views-dot{width:7px;height:7px;background:var(--red-light);border-radius:50%;animation:livePulse 1.2s infinite;flex-shrink:0;}
.vid-playing{
  display:flex;align-items:center;gap:6px;font-size:.72rem;font-weight:700;color:#fff;
  background:rgba(21,101,192,.85);
  padding:4px 10px;border-radius:20px;
  border:1px solid rgba(66,165,245,.5);
  box-shadow:0 2px 8px rgba(0,0,0,.4);
}
.eq-bars{display:flex;align-items:flex-end;gap:2px;height:14px;}
.eq-bar{width:3px;background:var(--blue-bright);border-radius:2px;animation:eqAnim .8s ease-in-out infinite alternate;}
.eq-bar:nth-child(1){animation-delay:0s;height:6px;}
.eq-bar:nth-child(2){animation-delay:.15s;height:10px;}
.eq-bar:nth-child(3){animation-delay:.3s;height:14px;}
.eq-bar:nth-child(4){animation-delay:.1s;height:8px;}
.eq-bar:nth-child(5){animation-delay:.25s;height:12px;}
@keyframes eqAnim{from{transform:scaleY(.25);}to{transform:scaleY(1);}}

/* CARD BODY */
.card-body{padding:16px 17px 4px;flex-grow:1;display:flex;flex-direction:column;gap:10px;}

.card-title{
  font-family:'Bebas Neue',sans-serif;font-size:1.4rem;
  color:#fff;letter-spacing:.05em;line-height:1.15;
}

/* Description — italic + blue left bar */
.card-desc-wrap{position:relative;}

.card-desc{
  font-size:.87rem;
  font-style:italic;
  font-weight:500;
  color:var(--text-soft);
  line-height:1.6;
  display:-webkit-box;
  -webkit-line-clamp:3;
  -webkit-box-orient:vertical;
  overflow:hidden;
  transition:all .3s ease;
  padding-left:14px;
  border-left:3px solid var(--blue-light);
}
.card-desc.expanded{-webkit-line-clamp:unset;overflow:visible;}

.desc-toggle{
  background:none;border:none;color:var(--blue-bright);
  font-size:.79rem;font-weight:700;font-family:inherit;font-style:italic;
  cursor:pointer;padding:4px 0;display:block;transition:var(--tr);
}
.desc-toggle:hover{color:#fff;}

/* Chips — RED */
.card-chips{display:flex;flex-wrap:wrap;gap:6px;padding-bottom:4px;}
.card-chip{
  background:rgba(211,47,47,.18);
  border:1px solid rgba(239,83,80,.45);
  color:#FF6B6B;
  font-size:.71rem;font-weight:800;
  padding:3px 10px;border-radius:20px;white-space:nowrap;
  text-shadow:0 0 6px rgba(239,83,80,.4);
}

/* CARD ACTIONS */
.card-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:12px 17px 17px;}

.btn-buy{
  background:linear-gradient(135deg,var(--blue),var(--blue-light));
  color:#fff;border:none;padding:12px 8px;border-radius:var(--radius-lg);
  font-weight:800;font-size:.88rem;font-family:inherit;cursor:pointer;
  transition:var(--tr);box-shadow:0 6px 18px rgba(21,101,192,.45);
  display:flex;align-items:center;justify-content:center;gap:6px;
  position:relative;overflow:hidden;
}
.btn-buy::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent 40%,rgba(255,255,255,.12));pointer-events:none;}
.btn-buy:hover{transform:scale(1.04);box-shadow:0 10px 28px rgba(21,101,192,.6);}

.btn-free{
  background:transparent;color:var(--text-soft);
  border:1px solid rgba(255,255,255,.14);
  padding:12px 8px;border-radius:var(--radius-lg);
  font-weight:700;font-size:.88rem;font-family:inherit;cursor:pointer;
  transition:var(--tr);
  display:flex;align-items:center;justify-content:center;gap:6px;
}
.btn-free:hover{border-color:rgba(66,165,245,.4);color:var(--blue-bright);background:rgba(30,136,229,.08);}

/* ─────────────────────────────────────────────
   OFFER CARDS
───────────────────────────────────────────── */
.offer-section{margin-top:68px;}
.offer-section-label{font-size:.69rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;color:var(--blue-bright);margin-bottom:18px;}
.custom-offer{display:flex;gap:20px;flex-wrap:wrap;}
.offer-card{
  background:var(--card-bg);border-radius:var(--radius-md);
  border:1px solid var(--card-border);padding:26px 22px;
  flex:1;min-width:255px;display:flex;flex-direction:column;gap:13px;
  box-shadow:var(--shadow-card);transition:var(--tr);
}
.offer-card:hover{border-color:rgba(66,165,245,.35);box-shadow:var(--shadow-card),0 0 24px rgba(30,136,229,.15);transform:translateY(-3px);}
.offer-card-icon{font-size:1.7rem;}
.offer-card h3{font-size:1.02rem;font-weight:800;color:#fff;}
.offer-card p{font-size:.87rem;color:var(--text-soft);margin-top:-5px;}
.offer-card textarea,
.offer-card input[type="text"]{
  width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);
  border-radius:var(--radius-sm);padding:12px 13px;font-size:.9rem;font-family:inherit;
  outline:none;transition:var(--tr);resize:vertical;color:var(--text);
}
.offer-card textarea:focus,
.offer-card input[type="text"]:focus{border-color:var(--blue-bright);background:rgba(30,136,229,.06);box-shadow:0 0 0 3px rgba(66,165,245,.14);}
.telegram-btn{
  background:linear-gradient(135deg,var(--blue),var(--blue-light));
  color:#fff;border:none;padding:13px 18px;border-radius:var(--radius-lg);
  font-weight:800;font-size:.93rem;font-family:inherit;width:100%;cursor:pointer;
  transition:var(--tr);box-shadow:0 6px 18px rgba(21,101,192,.4);
  display:flex;align-items:center;justify-content:center;gap:8px;margin-top:auto;
}
.telegram-btn:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 10px 26px rgba(21,101,192,.55);}

/* ─────────────────────────────────────────────
   MODALS (base)
───────────────────────────────────────────── */
.modal-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,5,20,.82);backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);z-index:9000;
  align-items:center;justify-content:center;padding:16px;
}
.modal-overlay.open{display:flex;animation:modalIn .25s cubic-bezier(.4,0,.2,1);}
@keyframes modalIn{from{opacity:0;transform:scale(.94);}to{opacity:1;transform:scale(1);}}

.modal-box{
  background:var(--card-bg);border:1px solid var(--card-border);
  border-radius:var(--radius-md);max-width:440px;width:100%;overflow:hidden;
  box-shadow:0 24px 60px rgba(0,0,0,.65),0 0 30px var(--blue-glow);
  position:relative;
}
.modal-close-x{
  position:absolute;top:13px;right:13px;
  background:rgba(255,255,255,.08);border:none;color:var(--text-soft);
  width:30px;height:30px;border-radius:50%;cursor:pointer;font-size:.95rem;
  z-index:10;transition:var(--tr);display:flex;align-items:center;justify-content:center;
}
.modal-close-x:hover{background:rgba(255,255,255,.2);color:#fff;}

/* Free available */
.free-available{padding:38px 28px 28px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:13px;}
.free-available .modal-icon{font-size:2.8rem;}
.free-available h3{font-size:1.2rem;font-weight:800;color:#fff;}
.free-available p{color:var(--text-soft);font-size:.89rem;}
.btn-access-folder{
  background:linear-gradient(135deg,#00897B,#00ACC1);color:#fff;border:none;
  padding:13px 26px;border-radius:var(--radius-lg);font-weight:800;font-size:.95rem;
  font-family:inherit;cursor:pointer;transition:var(--tr);width:100%;margin-top:4px;
  box-shadow:0 6px 18px rgba(0,137,123,.4);
}
.btn-access-folder:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(0,137,123,.55);}

/* Free unavailable */
.free-unavailable{padding:38px 28px 28px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:13px;}
.free-unavailable .modal-icon{font-size:2.6rem;filter:grayscale(.4);}
.free-unavailable h3{font-size:1.05rem;font-weight:800;color:#fff;}
.free-unavailable p{color:var(--text-soft);font-size:.87rem;}
.free-contact-btns{display:flex;flex-direction:column;gap:10px;width:100%;margin-top:4px;}
.btn-contact-tg{
  background:linear-gradient(135deg,#0088CC,#0099E6);color:#fff;border:none;
  padding:12px;border-radius:var(--radius-lg);font-weight:700;font-size:.91rem;
  font-family:inherit;cursor:pointer;transition:var(--tr);
  display:flex;align-items:center;justify-content:center;gap:8px;
}
.btn-contact-tg:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(0,136,204,.4);}

/* ZANGI button in modal — GREEN */
.btn-contact-zangi{
  background:linear-gradient(135deg,var(--green-dark),var(--green));color:#fff;border:none;
  padding:12px;border-radius:var(--radius-lg);font-weight:700;font-size:.91rem;
  font-family:inherit;cursor:pointer;transition:var(--tr);
  display:flex;align-items:center;justify-content:center;gap:8px;
  box-shadow:0 4px 14px var(--green-glow);
}
.btn-contact-zangi:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(0,200,83,.55);}

/* ─────────────────────────────────────────────
   PROOF MODAL
───────────────────────────────────────────── */
.proof-modal-box{max-width:520px;}
.modal-header-bar{
  padding:16px 20px 13px;
  background:linear-gradient(135deg,var(--blue),var(--blue-light));
  color:#fff;font-weight:700;font-size:.95rem;
  display:flex;justify-content:space-between;align-items:center;
}
.modal-close-btn{
  background:rgba(255,255,255,.2);border:none;color:#fff;
  width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:.95rem;
  display:flex;align-items:center;justify-content:center;transition:var(--tr);
}
.modal-close-btn:hover{background:rgba(255,255,255,.35);}

.modal-body{padding:20px 22px 22px;text-align:center;}

.proof-img-wrap{
  position:relative;display:flex;align-items:center;gap:8px;
  justify-content:center;
}

/* Proof image — clickable for fullscreen */
.modal-body img{
  flex:1;border-radius:var(--radius-sm);object-fit:contain;
  max-height:290px;width:100%;cursor:zoom-in;
  transition:transform .2s ease;
  border:2px solid rgba(66,165,245,.2);
}
.modal-body img:hover{transform:scale(1.015);border-color:rgba(66,165,245,.5);}

/* Nav arrows */
.proof-nav{
  background:rgba(21,101,192,.8);border:1px solid rgba(66,165,245,.5);
  color:#fff;width:36px;height:36px;border-radius:50%;
  font-size:1.3rem;cursor:pointer;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  transition:var(--tr);
}
.proof-nav:hover{background:var(--blue);transform:scale(1.1);}

.proof-counter{
  font-size:.78rem;font-weight:700;color:var(--text-soft);
  margin-top:8px;
}
.modal-caption{font-size:.83rem;color:var(--text-soft);margin-top:6px;}

.btn-zoom{
  margin-top:12px;background:rgba(30,136,229,.15);border:1px solid rgba(66,165,245,.35);
  color:var(--blue-bright);padding:8px 20px;border-radius:var(--radius-lg);
  font-size:.82rem;font-weight:700;font-family:inherit;cursor:pointer;transition:var(--tr);
}
.btn-zoom:hover{background:rgba(30,136,229,.28);color:#fff;}

/* ─────────────────────────────────────────────
   PROOF FULLSCREEN
───────────────────────────────────────────── */
.proof-fullscreen{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,10,.96);backdrop-filter:blur(6px);
  z-index:10000;align-items:center;justify-content:center;
  padding:20px;cursor:zoom-out;
}
.proof-fullscreen.open{display:flex;animation:modalIn .2s ease;}
.proof-fullscreen img{
  max-width:100%;max-height:calc(100vh - 60px);
  object-fit:contain;border-radius:var(--radius-sm);
  box-shadow:0 0 60px rgba(0,0,0,.8);
  cursor:default;
}
.proof-fs-close{
  position:fixed;top:20px;right:20px;
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);
  color:#fff;width:42px;height:42px;border-radius:50%;cursor:pointer;
  font-size:1.2rem;display:flex;align-items:center;justify-content:center;
  transition:var(--tr);z-index:1;
}
.proof-fs-close:hover{background:rgba(255,255,255,.25);}

/* ─────────────────────────────────────────────
   LIVE NOTIFICATIONS — bottom-left
───────────────────────────────────────────── */
#live-notifications{
  position:fixed;bottom:24px;left:18px;z-index:8000;
  max-width:295px;pointer-events:none;
}
.notification-item{
  background:var(--card-bg);border-radius:var(--radius-sm);
  padding:11px 14px;margin-top:9px;
  border-left:3px solid var(--blue-light);
  box-shadow:0 8px 28px rgba(0,0,0,.5),0 0 0 1px rgba(66,165,245,.13);
  font-size:.81rem;pointer-events:auto;line-height:1.5;color:var(--text);
  animation:notifIn .4s cubic-bezier(.4,0,.2,1),notifOut .5s 4.3s cubic-bezier(.4,0,.2,1) forwards;
}
.notification-item strong{color:var(--blue-bright);}
.notification-item small{color:var(--text-soft);}
@keyframes notifIn{from{transform:translateX(-110%);opacity:0;}to{transform:translateX(0);opacity:1;}}
@keyframes notifOut{to{transform:translateX(-110%);opacity:0;}}

/* ─────────────────────────────────────────────
   FOOTER
───────────────────────────────────────────── */
.site-footer{background:#050A18;border-top:1px solid rgba(66,165,245,.14);position:relative;overflow:hidden;}
.footer-glow{
  position:absolute;width:500px;height:220px;
  background:radial-gradient(ellipse,rgba(21,101,192,.13) 0%,transparent 70%);
  bottom:0;left:50%;transform:translateX(-50%);pointer-events:none;
}
.footer-inner{
  max-width:1280px;margin:0 auto;
  padding:50px 24px 38px;
  display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;
}
@media(max-width:720px){.footer-inner{grid-template-columns:1fr;gap:30px;}}

.footer-logo{
  font-family:'Bebas Neue',sans-serif;font-size:2rem;
  color:#fff;letter-spacing:.08em;
  text-shadow:0 0 20px rgba(66,165,245,.35);margin-bottom:9px;
}
.footer-logo span{color:var(--blue-bright);}
.footer-tagline{font-size:.87rem;color:var(--text-soft);line-height:1.6;margin-bottom:14px;}

.footer-social-btns{display:flex;gap:10px;}
.foot-social-btn{
  width:40px;height:40px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:var(--tr);text-decoration:none;flex-shrink:0;
}
.tg-foot{background:linear-gradient(135deg,#0088CC,#0099E6);color:#fff;box-shadow:0 4px 12px rgba(0,136,204,.4);}
.tg-foot:hover{transform:translateY(-3px) scale(1.1);box-shadow:0 8px 20px rgba(0,136,204,.6);}
/* Zangi in footer — GREEN */
.zangi-foot{background:linear-gradient(135deg,var(--green-dark),var(--green));color:#fff;box-shadow:0 4px 12px var(--green-glow);}
.zangi-foot:hover{transform:translateY(-3px) scale(1.1);box-shadow:0 8px 20px rgba(0,200,83,.55);}

.footer-col-title{font-size:.68rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--blue-bright);margin-bottom:14px;}
.footer-links-col{display:flex;flex-direction:column;gap:11px;}
.footer-links-col a{
  color:var(--text-soft);text-decoration:none;font-size:.87rem;font-weight:500;
  display:flex;align-items:center;gap:7px;transition:var(--tr);
}
.footer-links-col a:hover{color:#fff;}

.footer-bottom{
  max-width:1280px;margin:0 auto;
  padding:18px 24px 26px;border-top:1px solid rgba(255,255,255,.05);
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:10px;font-size:.79rem;color:var(--text-dim);
}
.footer-badges{display:flex;gap:8px;flex-wrap:wrap;}
.foot-badge{
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);
  border-radius:20px;padding:3px 11px;font-size:.75rem;font-weight:700;color:var(--text-soft);
}

/* ─────────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────────── */
@media(max-width:600px){
  .header-inner{gap:10px;}
  .header-right{width:100%;justify-content:center;flex-direction:column;align-items:center;gap:10px;}
  .header-contacts{justify-content:center;}
  .logo-text{font-size:1.45rem;}
  .card-actions{grid-template-columns:1fr;}
  .section-title{font-size:1.9rem;}
  .official-notice{padding:9px 14px;}
  .notice-text{font-size:.7rem;letter-spacing:.06em;}
  #live-notifications{max-width:250px;left:10px;bottom:14px;}
  .proof-modal-box{max-width:100%;}
}

/* Scrollbar */
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:var(--dark2);}
::-webkit-scrollbar-thumb{background:var(--blue);border-radius:3px;}
